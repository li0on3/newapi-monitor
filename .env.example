NEW_API_BASE_URL=http://host.docker.internal:3000
NEW_API_ACCESS_TOKEN=replace-with-dedicated-admin-access-token
NEW_API_USER_ID=1
RELAY_API_TOKEN=replace-with-dedicated-minimal-relay-token
REAL_PROBE_RULES={}
EXCLUDED_TOKEN_NAMES=模型测试,newapi-monitor-probe

STATE_DB=/data/monitor.db
POLL_SECONDS=5
CHANNEL_SYNC_INTERVAL_SECONDS=5
CHANNEL_INTERVAL_SECONDS=300
CHANNEL_PROBE_CONCURRENCY=3
CHANNEL_FAILURE_THRESHOLD=2
CHANNEL_RECOVERY_THRESHOLD=2
LOG_INTERVAL_SECONDS=30
RESOURCE_INTERVAL_SECONDS=15
REPORT_INTERVAL_SECONDS=86400
LOG_INITIAL_LOOKBACK_SECONDS=3600
LOG_OVERLAP_SECONDS=60
RETENTION_DAYS=90

SLOW_REQUEST_SECONDS=60
LATENCY_HARD_LIMIT_SECONDS=180
LATENCY_REMINDER_SECONDS=1800
CHANNEL_SLOW_SECONDS=60
CHANNEL_STALE_SECONDS=900
RESOURCE_SUSTAIN_SECONDS=180
SYSTEM_CPU_THRESHOLD=85
SYSTEM_MEMORY_THRESHOLD=85
SYSTEM_DISK_THRESHOLD=80
CONTAINER_CPU_THRESHOLD=90
CONTAINER_MEMORY_THRESHOLD=90

DOCKER_CONTAINER_NAME=new-api
DOCKER_CONTAINER_NAMES=new-api,postgres,redis
DISK_PATH=/

DASHBOARD_ADMIN_USERNAME=admin
DASHBOARD_ADMIN_PASSWORD=not-a-real-password
DASHBOARD_SESSION_SECONDS=604800
DASHBOARD_COOKIE_NAME=newapi_monitor_session
DASHBOARD_COOKIE_PATH=/monitor
DASHBOARD_COOKIE_SECURE=true
DASHBOARD_FORCE_PASSWORD_SYNC=false
MONITOR_WORKER_ENABLED=true
TRUST_PROXY_HEADERS=true
DASHBOARD_ALLOWED_HOSTS=monitor.example.com,localhost,127.0.0.1
MONITOR_SECRET_KEY=replace-with-a-random-secret-generated-by-manage-py
MONITOR_BIND_ADDRESS=127.0.0.1
MONITOR_PORT=18081
SETUP_TOKEN_HASH=
SETUP_TOKEN_EXPIRES_AT=0

# Key 用量查询（首次启动默认值，之后可在系统配置中动态修改）
KEY_USAGE_ENABLED=true
KEY_USAGE_MIN_ROLE=admin
KEY_USAGE_LOG_LIMIT=100
KEY_USAGE_ATTEMPTS_PER_MINUTE=10
KEY_USAGE_QUOTA_PER_UNIT=500000

# OpenAI 官方状态（首次启动默认值，之后可在系统配置中动态修改）
OPENAI_STATUS_ENABLED=true
OPENAI_STATUS_ALERT_ENABLED=true
OPENAI_STATUS_INTERVAL_SECONDS=60
OPENAI_STATUS_TIMEOUT_SECONDS=10
OPENAI_STATUS_MIN_IMPACT=major
# 留空时默认关注 Responses、Chat Completions、Codex API 和 CLI；也可填写逗号分隔的组件 ID
OPENAI_STATUS_COMPONENT_IDS=
OPENAI_STATUS_FAILURE_THRESHOLD=2
OPENAI_STATUS_RECOVERY_THRESHOLD=2
OPENAI_STATUS_INCLUDE_IN_OVERALL=false
OPENAI_STATUS_ADMIN_VISIBLE=true
OPENAI_STATUS_VIEWER_VISIBLE=true

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=replace-with-smtp-user
SMTP_PASSWORD=replace-with-smtp-password
SMTP_FROM=newapi-monitor@example.com
SMTP_TO=you@example.com
SMTP_STARTTLS=true
SMTP_SSL=false
EMAIL_ENABLED=true

# 企业微信自建应用
WECOM_APP_ENABLED=false
WECOM_CORP_ID=
WECOM_AGENT_ID=0
WECOM_APP_SECRET=
WECOM_TO_USER=@all
WECOM_TO_PARTY=
WECOM_TO_TAG=

# 企业微信群机器人
WECOM_WEBHOOK_ENABLED=false
WECOM_WEBHOOK_URL=

# 飞书自建应用；发送时仍需 receive_id
FEISHU_APP_ENABLED=false
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_RECEIVE_ID_TYPE=chat_id
FEISHU_RECEIVE_ID=

# 飞书群机器人；未启用签名校验时 Secret 可留空
FEISHU_WEBHOOK_ENABLED=false
FEISHU_WEBHOOK_URL=
FEISHU_WEBHOOK_SECRET=

SEND_STARTUP_EMAIL=true
SUBJECT_PREFIX=[New API监控]
LOG_LEVEL=INFO
